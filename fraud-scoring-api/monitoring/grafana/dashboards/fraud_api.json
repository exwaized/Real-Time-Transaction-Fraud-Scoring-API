{
  "title": "Fraud Scoring API — Live Monitor",
  "uid": "fraud-api-v1",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 6},
      "targets": [{
        "expr": "rate(fraud_api_requests_total[1m])",
        "legendFormat": "{{risk_tier}} / {{model}}"
      }]
    },
    {
      "id": 2,
      "title": "Rolling Fraud Rate (5min)",
      "type": "gauge",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 6},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "thresholds": {
          "steps": [
            {"color": "green", "value": 0},
            {"color": "yellow", "value": 0.01},
            {"color": "red", "value": 0.02}
          ]
        }
      },
      "targets": [{"expr": "fraud_rate_rolling_5min", "legendFormat": "Fraud Rate"}]
    },
    {
      "id": 3,
      "title": "P99 Scoring Latency (ms)",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 6},
      "targets": [{
        "expr": "histogram_quantile(0.99, rate(fraud_score_latency_seconds_bucket[5m])) * 1000",
        "legendFormat": "p99 ms"
      }]
    },
    {
      "id": 4,
      "title": "P50 / P95 / P99 Latency",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 6},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(fraud_score_latency_seconds_bucket[1m])) * 1000", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(fraud_score_latency_seconds_bucket[1m])) * 1000", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, rate(fraud_score_latency_seconds_bucket[1m])) * 1000", "legendFormat": "p99"}
      ]
    },
    {
      "id": 5,
      "title": "Fraud Score Distribution",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 6},
      "targets": [{
        "expr": "rate(fraud_score_distribution_bucket[5m])",
        "legendFormat": "le={{le}}"
      }]
    },
    {
      "id": 6,
      "title": "Risk Tier Breakdown",
      "type": "piechart",
      "gridPos": {"x": 12, "y": 6, "w": 6, "h": 6},
      "targets": [{
        "expr": "sum by (risk_tier) (fraud_api_requests_total)",
        "legendFormat": "{{risk_tier}}"
      }]
    },
    {
      "id": 7,
      "title": "Rule-Based Flag Rate",
      "type": "timeseries",
      "gridPos": {"x": 18, "y": 6, "w": 6, "h": 6},
      "targets": [{
        "expr": "rate(rule_based_flags_total[1m])",
        "legendFormat": "{{rule}}"
      }]
    },
    {
      "id": 8,
      "title": "Champion vs Challenger Divergence",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 6},
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(challenger_score_divergence_bucket[5m]))",
        "legendFormat": "p95 delta"
      }]
    },
    {
      "id": 9,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": {"x": 12, "y": 12, "w": 4, "h": 6},
      "targets": [{"expr": "sum(fraud_api_requests_total)", "legendFormat": "Total"}]
    }
  ]
}
